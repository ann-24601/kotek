# Kotek — przykładowe zmienne środowiskowe.
# Skopiuj do .env.local i uzupełnij. NIE commituj .env.local.
# W Vercel ustaw te same zmienne (Production + Preview).

# --- Supabase (klient/przeglądarka) ---
NEXT_PUBLIC_SUPABASE_URL=https://<projekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# --- OpenAI (behawiorysta: /api/chat oraz /api/v1/ask, serwerowo) ---
OPENAI_API_KEY=sk-...

# --- API v1 (/api/v1/*) oraz serwer MCP (/api/mcp), serwerowo ---
# Klucz service_role Supabase OMIJAJĄCY RLS — tylko serwer, NIGDY w kliencie.
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Autoryzacja API/MCP jest PER-UŻYTKOWNIK: każdy generuje własny token na /docs
# (tabela api_tokens, trzymany jako hash). Poniższe dwie zmienne to już TYLKO
# opcjonalny fallback na czas migracji — wspólny token mapowany na jedno konto.
# Można je pominąć, gdy korzystasz wyłącznie z tokenów osobistych.
# UID konta dla fallbacku (auth.users.id).
KOTEK_USER_ID=<uuid>
# Wspólny (legacy) token. Nagłówek: Authorization: Bearer <token>.
# Wygeneruj: openssl rand -hex 32. Rotowalny.
KOTEK_API_TOKEN=<hex32>

# --- Stripe (płatne agenty, np. Behawiorysta PRO) ---
# Publiczny URL Stripe Payment Link dla wersji PRO (może być w przeglądarce).
# Po jego otwarciu doklejamy ?client_reference_id=<user_id>&prefilled_email=<email>.
NEXT_PUBLIC_STRIPE_PRO_PAYMENT_LINK=https://buy.stripe.com/...
# Klucz API Stripe (sk_test_... / sk_live_...) — TYLKO serwer, traktuj jak hasło.
STRIPE_SECRET_KEY=sk_test_...
# Sekret podpisu webhooka (whsec_...) z panelu Stripe → Webhooks. TYLKO serwer.
STRIPE_WEBHOOK_SECRET=whsec_...
