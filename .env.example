# Kotek — przykładowe zmienne środowiskowe.
# Skopiuj do .env.local i uzupełnij. NIE commituj .env.local.
# W Vercel ustaw te same zmienne (Production + Preview).

# --- Supabase (klient/przeglądarka) ---
NEXT_PUBLIC_SUPABASE_URL=https://<projekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# --- OpenAI (behawiorysta: /api/chat oraz /api/v1/ask, serwerowo) ---
OPENAI_API_KEY=sk-...

# --- API v1 (/api/v1/*) oraz serwer MCP (/api/mcp), serwerowo ---
# Klucz service_role Supabase OMIJAJĄCY RLS — tylko serwer, NIGDY w kliencie.
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
# UID właściciela danych (auth.users.id) — na to konto działają endpointy.
KOTEK_USER_ID=<uuid>
# Personal Access Token do autoryzacji API ORAZ serwera MCP (/api/mcp).
# Nagłówek: Authorization: Bearer <token>. Wygeneruj: openssl rand -hex 32. Rotowalny.
KOTEK_API_TOKEN=<hex32>
